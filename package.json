{
  "name": "auto-showcase-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "build:lib": "turbo run build --filter=auto-showcase",
    "docs": "turbo run dev --filter=docs",
    "testing": "turbo run dev --filter=testing",
    "generate": "pnpm --filter=testing generate"
  },
  "devDependencies": {
    "turbo": "^2.5.5",
    "typescript": "^6.0.3"
  }
}
