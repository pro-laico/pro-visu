{
  "name": "auto-showcase",
  "version": "0.1.0",
  "description": "A portable CLI for generating showcase assets (scroll reels, and more) of the websites you build.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "showcase",
    "playwright",
    "video",
    "screenshot",
    "marketing",
    "cli",
    "portfolio"
  ],
  "bin": {
    "showcase": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "c12": "^3.3.4",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "ffmpeg-static": "^5.3.0",
    "image-size": "^2.0.2",
    "picocolors": "^1.1.1",
    "playwright-core": "^1.60.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  }
}
