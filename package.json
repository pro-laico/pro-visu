{
  "name": "pro-visu-monorepo",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=18.18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "build:lib": "turbo run build --filter=pro-visu",
    "docs": "turbo run dev --filter=docs",
    "testing": "turbo run dev --filter=testing",
    "generate": "turbo run generate --filter=testing",
    "release": "node tools/releaser/release.mjs",
    "publish-packages": "node tools/releaser/publish.mjs"
  },
  "devDependencies": {
    "turbo": "^2.10.5",
    "typescript": "^6.0.3"
  }
}
