# next-video → Mux credentials (create an access token in the Mux dashboard:
# Settings → Access Tokens, with "Mux Video" read+write). Copy this file to
# `.env.local` (gitignored) for local processing, and set the same vars in the
# Vercel project env for deploy-time/`next-video sync` processing.
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
