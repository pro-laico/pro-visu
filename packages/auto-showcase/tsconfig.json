{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    // tsup's .d.ts builder injects baseUrl to resolve `paths`; TS 6 deprecates it but it
    // still functions. Silence the deprecation (revisit before TS 7).
    "ignoreDeprecations": "6.0",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    // The CLI dashboard is built with Ink (React) via the automatic JSX runtime.
    "jsx": "react-jsx",
    "types": ["node"],

    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,

    "paths": {
      "@/*": ["./src/*"]
    },

    "noEmit": true
  },
  "include": ["src", "test", "tsup.config.ts", "vitest.config.ts"]
}
