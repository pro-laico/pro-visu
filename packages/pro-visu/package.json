{
  "name": "pro-visu",
  "version": "0.2.0",
  "description": "A portable CLI for generating showcase assets (scroll reels, and more) of the websites you build.",
  "type": "module",
  "license": "MIT",
  "author": "Pro Laico",
  "homepage": "https://pro-visu.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pro-laico/pro-visu.git",
    "directory": "packages/pro-visu"
  },
  "bugs": {
    "url": "https://github.com/pro-laico/pro-visu/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "pro-visu",
    "playwright",
    "video",
    "screenshot",
    "marketing",
    "cli",
    "portfolio"
  ],
  "bin": {
    "pro-visu": "./dist/cli/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.18"
  },
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && tsup && pnpm build:scene",
    "build:scene": "vite build -c scene-app/vite.config.ts",
    "build:cli": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scene-app/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepare": "pnpm build",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "c12": "^3.3.4",
    "cac": "^7.0.0",
    "consola": "^3.4.2",
    "ffmpeg-static": "^5.3.0",
    "image-size": "^2.0.2",
    "ink": "^7.0.6",
    "picocolors": "^1.1.1",
    "playwright-core": "^1.60.0",
    "react": "^19.2.7",
    "update-notifier": "^7.3.1",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^4.3.4",
    "ink-testing-library": "^4.0.0",
    "react-dom": "^19.2.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "unocss": "^66.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.8"
  }
}
